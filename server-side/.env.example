# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=liondesk_db

# Security
JWT_SECRET=your_jwt_secret_key_change_me_in_production
